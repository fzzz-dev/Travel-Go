# ── Flask ──────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string-in-production
DEBUG=False

# ── JWT ────────────────────────────────────────────────────────
JWT_EXPIRY_HOURS=24

# ── AWS ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# ── DynamoDB Tables ────────────────────────────────────────────
USERS_TABLE=TravelGo_Users
TRANSPORT_TABLE=TravelGo_TransportListings
HOTELS_TABLE=TravelGo_Hotels
BOOKINGS_TABLE=TravelGo_Bookings

# ── SNS (optional) ─────────────────────────────────────────────
# Create SNS topics in AWS Console, paste ARNs here
SNS_BOOKING_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:TravelGo-BookingConfirmed
SNS_CANCEL_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:TravelGo-BookingCancelled

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://YOUR_EC2_PUBLIC_IP
